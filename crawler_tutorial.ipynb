    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "HgrW0iqlGr8p",
      "metadata": {
        "id": "HgrW0iqlGr8p"
      },
      "outputs": [],
      "source": [
        "import requests\n",
        "import datetime\n",
        "\n",
        "url = 'https://opendata.cwb.gov.tw/fileapi/v1/opendataapi/F-A0010-001?Authorization=CWB-96773A4C-114C-4BDB-BF04-D576A80B2059&downloadType=WEB&format=JSON'\n",
        "\n",
        "response = requests.get(url)\n",
        "if response.status_code == 200:\n",
        "    data = response.json()\n",
        "    taichung_data = []\n",
        "    today = datetime.datetime.now()\n",
        "    parser_data = data['cwbdata']['resources']['resource']['data']['agrWeatherForecasts']['weatherForecasts']['location']\n",
        "    \n",
        "    for i in parser_data:\n",
        "        if i['locationName'] == '中部地區':\n",
        "            daily = i\n",
        "\n",
        "    # Version 1\n",
        "    daily_store = daily\n",
        "    daily_forecasts = daily['weatherElements']['Wx']['daily']\n",
        "    for raw in daily_forecasts:\n",
        "        temp_data = {}\n",
        "        temp_data['location_name'] = '中部地區'\n",
        "        temp_data['date'] = raw['dataDate']\n",
        "        temp_data['forecasts_result'] = raw['weather']\n",
        "        taichung_data.append(temp_data)\n",
        "    print(taichung_data)\n",
        "    \n",
        "    # Version 2\n",
        "    daily_elements = daily_store['weatherElements']\n",
        "    for weather in daily_elements:\n",
        "        for forecast in daily_elements[weather]:\n",
        "            print(weather)\n",
        "            for raw in daily_elements[weather][forecast]:\n",
        "                print(raw)\n",
        "else:\n",
        "    print('Error getting data:', response.status_code)\n"
      ]
    },
