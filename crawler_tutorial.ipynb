        "payload = {'key1': 'value1', 'key2': 'value2'}\n",
        "url = \"http://httpbin.org/get\"\n",
        "\n",
        "r = requests.get(\"http://httpbin.org/get\", params=payload)\n",
        "\n",
        "print(r.url)\n",
        "print(r.text)"
      ]
