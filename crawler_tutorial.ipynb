        "id": "cI_4f0i-HdlF"
      },
      "outputs": [],
      "source": [
        "params_1 = 'value1'\n",
        "params_2 = 'value2'\n",
        "# url = \"http://httpbin.org/get?key1=%s&key2=%s\" % (params_1, params_2)\n",
        "# url = \"http://httpbin.org/get?key1={}&key2={}\".format(params_1, params_2)\n",
        "url = f\"http://httpbin.org/get?key1={params_1}&key2={params_2}\"\n",
        "\n",
        "r = requests.get(url)\n",
        "r.encoding = 'utf-8'\n",
        "\n",
        "print(r.url)\n",
        "print(r.text)"
      ]
