      "source": [
        "# API 爬回來是 json 檔\n",
        "url1='https://github.com/timeline.json'\n",
        "url2='https://opendata.cwb.gov.tw/fileapi/v1/opendataapi/C-A0007-001?Authorization=CWB-96773A4C-114C-4BDB-BF04-D576A80B2059&downloadType=WEB&format=JSON'\n",
        "url=url2\n",
        "r=requests.get(url)\n",
        "print(f'type of r is {type(r)}')\n",
        "res=r.text\n",
        "print(f'type of r.text is {type(res)}') # 字串形式\n",
        "print(res) # 不能被python 直接利用 (dictionary, pandas DataFrame 類型才可直接存放ＤＢ)\n",
        "\n"
      ]
    },
