        "d = json.loads(res)\n",
        "print(d)\n",
        "print(type(d))\n",
        "\n",
        "if (url==url1):\n",
        "  arg1=d['message'] \n",
        "  arg2=d['documentation_url']\n",
        "  print(f'documentation url is {arg2}')\n",
        "\n",
        "if(url==url2):\n",
        "  arg1=d['cwbopendata']['dataset']['resource']['uri']\n",
